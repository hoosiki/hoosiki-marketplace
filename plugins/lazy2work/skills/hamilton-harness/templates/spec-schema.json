{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoosiki.io/hamilton-harness/spec-schema/v1.0.json",
  "title": "hamilton-harness DAG Spec v1.0",
  "type": "object",
  "required": ["name", "nodes"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Snake-case pipeline identifier"
    },
    "description": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0"
    },
    "schemas": {
      "type": "array",
      "items": { "$ref": "#/$defs/PydanticSchema" }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Node" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "Node": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": { "type": "string" },
        "source": {
          "type": "string",
          "enum": ["input"]
        },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "invariants": {
          "type": "array",
          "items": { "$ref": "#/$defs/Invariant" }
        },
        "tags": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        }
      },
      "oneOf": [
        {
          "required": ["source"],
          "not": { "required": ["inputs"] }
        },
        {
          "required": ["inputs"],
          "not": { "required": ["source"] }
        },
        {
          "not": {
            "anyOf": [
              { "required": ["source"] },
              { "required": ["inputs"] }
            ]
          }
        }
      ]
    },
    "Invariant": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "properties": {
        "range": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "no_nulls": { "type": "boolean" },
        "values": {
          "type": "array",
          "minItems": 1
        },
        "regex": { "type": "string" }
      },
      "additionalProperties": false
    },
    "PydanticSchema": {
      "type": "object",
      "required": ["name", "fields"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "fields": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/FieldDef" }
        }
      }
    },
    "FieldDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string" },
        "ge": { "type": "number" },
        "le": { "type": "number" },
        "gt": { "type": "number" },
        "lt": { "type": "number" },
        "min_length": { "type": "integer", "minimum": 0 },
        "max_length": { "type": "integer", "minimum": 0 },
        "pattern": { "type": "string" },
        "nullable": { "type": "boolean" },
        "values": {
          "type": "array",
          "minItems": 1
        },
        "description": { "type": "string" }
      }
    }
  }
}
