# Webhook configuration for Claude Code notification hooks.
# Copy this file to .env and fill in your values.

# Required: Webhook endpoint URL
CLAUDE_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxx

# Optional: Auth token (used as Bearer token or Synology token parameter)
CLAUDE_WEBHOOK_TOKEN=

# Optional: Payload format — generic, slack, discord, or synology (default: generic)
CLAUDE_WEBHOOK_FORMAT=slack
